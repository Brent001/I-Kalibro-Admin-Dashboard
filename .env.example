# Replace with your DB credentials!
DATABASE_URL="postgresql://<db_user>:<db_password>@<db_host>/<db_name>?sslmode=require&channel_binding=require"
#DATABASE_URL="postgres://postgres:<password>@localhost:5432/<db_name>"
JWT_SECRET="<your_jwt_secret>"
JWT_REFRESH_SECRET="<your_jwt_refresh_secret>"

# Replace with your Redis credentials!
UPSTASH_REDIS_REST_URL="https://<your_upstash_redis_host>"
UPSTASH_REDIS_REST_TOKEN="<your_upstash_redis_rest_token>"

VITE_RESEND_API_KEY="<your_resend_api_key>"
CRON_SECRET="<your_cron_secret>"
VITE_ENCRYPTION_KEY="<your_encryption_key>"

# Backblaze B2 Configuration (VITE_ prefix for client-accessible vars)
VITE_BACKBLAZE_KEY_ID="<your_backblaze_key_id>"
VITE_BACKBLAZE_APPLICATION_KEY="<your_backblaze_application_key>"
VITE_BACKBLAZE_BUCKET_NAME="<your_backblaze_bucket_name>"
VITE_BACKBLAZE_BUCKET_ID="<your_backblaze_bucket_id>"
VITE_BACKBLAZE_REGION="<your_backblaze_region>"
